<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_saran_otp_oth" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.saran.otp.oth</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='mobile']" position="after">
                <field name="saran_otp_mobile_verified"/>
                <field name="saran_otp_mobile_verified_at" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
