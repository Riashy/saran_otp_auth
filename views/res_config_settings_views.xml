<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_saran_otp_oth" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.saran.otp.oth</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="OTP Authentication" name="saran_otp_oth" groups="base.group_system">
                    <block title="OTP Features">
                        <setting string="OTP Login">
                            <field name="saran_otp_enable_login"/>
                        </setting>
                        <setting string="OTP Signup">
                            <field name="saran_otp_enable_signup"/>
                        </setting>
                        <setting string="OTP Checkout Verification">
                            <field name="saran_otp_enable_checkout"/>
                        </setting>
                    </block>
                    <block title="Victory Link Gateway">
                        <setting string="Gateway Username">
                            <field name="saran_otp_gateway_username"/>
                        </setting>
                        <setting string="Gateway Password">
                            <field name="saran_otp_gateway_password"/>
                        </setting>
                        <setting string="Sender Name">
                            <field name="saran_otp_sender_name"/>
                        </setting>
                        <setting string="Send URL">
                            <field name="saran_otp_send_url"/>
                        </setting>
                        <setting string="Check Credit URL">
                            <field name="saran_otp_credit_url"/>
                        </setting>
                        <setting string="Default Country Code">
                            <field name="saran_otp_default_country_code"/>
                        </setting>
                    </block>
                    <block title="OTP Policy">
                        <setting string="OTP Length">
                            <field name="saran_otp_length"/>
                        </setting>
                        <setting string="Validity (Minutes)">
                            <field name="saran_otp_validity_minutes"/>
                        </setting>
                        <setting string="Resend Cooldown (Seconds)">
                            <field name="saran_otp_resend_cooldown_seconds"/>
                        </setting>
                        <setting string="Max Attempts">
                            <field name="saran_otp_max_attempts"/>
                        </setting>
                        <setting string="HTTP Timeout (Seconds)">
                            <field name="saran_otp_http_timeout"/>
                        </setting>
                        <setting string="SMS Template">
                            <field name="saran_otp_message_template"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
