<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="web_login_inherit_saran_otp_oth" inherit_id="web.login" name="Web Login OTP Link">
        <xpath expr="//form[hasclass('oe_login_form')]" position="after">
            <div class="text-center mt-3">
                <a href="/otp/login" class="btn btn-outline-primary btn-sm">Login with OTP</a>
                <a href="/otp/signup" class="btn btn-outline-secondary btn-sm ms-2">Signup with OTP</a>
            </div>
        </xpath>
    </template>

    <template id="website_sale_payment_inherit_saran_otp_oth" inherit_id="website_sale.payment" name="Website Sale Payment OTP Notice">
        <xpath expr="//div[hasclass('oe_website_sale')]" position="inside">
            <div class="alert alert-info mt-3" t-if="request.env['ir.config_parameter'].sudo().get_param('saran_otp_oth.enable_checkout') == 'True'">
                Payment is protected with OTP verification. If your order is not yet verified, you will be redirected automatically.
            </div>
        </xpath>
    </template>

    <template id="otp_login_page" name="OTP Login Page">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <section class="container py-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-5 col-md-7">
                            <div class="card shadow-sm">
                                <div class="card-body p-4">
                                    <h2 class="h4 mb-3 text-center">Login with OTP</h2>
                                    <p class="text-muted text-center">Use your mobile number to receive a one-time password.</p>
                                    <div t-if="error" class="alert alert-danger" t-esc="error"/>
                                    <div t-if="success" class="alert alert-success" t-esc="success"/>

                                    <form t-if="not otp_sent" action="/otp/login/send" method="post" class="mt-3">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <div class="mb-3">
                                            <label class="form-label">Mobile Number</label>
                                            <input type="text" name="mobile" t-att-value="mobile or ''" class="form-control" required="required"/>
                                        </div>
                                        <button type="submit" class="btn btn-primary w-100">Send OTP</button>
                                    </form>

                                    <form t-if="otp_sent" action="/otp/login/verify" method="post" class="mt-3">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <div class="mb-3">
                                            <label class="form-label">OTP Code</label>
                                            <input type="text" name="code" class="form-control" required="required"/>
                                            <small class="text-muted">Code sent to <t t-esc="masked_mobile"/>.</small>
                                        </div>
                                        <button type="submit" class="btn btn-success w-100">Verify and Login</button>
                                    </form>

                                    <div class="text-center mt-3">
                                        <a href="/web/login">Back to standard login</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <template id="otp_signup_page" name="OTP Signup Page">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <section class="container py-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-6 col-md-8">
                            <div class="card shadow-sm">
                                <div class="card-body p-4">
                                    <h2 class="h4 mb-3 text-center">Signup with OTP</h2>
                                    <p class="text-muted text-center">Create a website account and verify the mobile number before activation.</p>
                                    <div t-if="error" class="alert alert-danger" t-esc="error"/>
                                    <div t-if="success" class="alert alert-success" t-esc="success"/>

                                    <form t-if="not otp_sent" action="/otp/signup/send" method="post" class="row g-3">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <div class="col-12">
                                            <label class="form-label">Name</label>
                                            <input type="text" name="name" t-att-value="(payload or {}).get('name', '')" class="form-control" required="required"/>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Login</label>
                                            <input type="text" name="login" t-att-value="(payload or {}).get('login', '')" class="form-control" required="required"/>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Email</label>
                                            <input type="email" name="email" t-att-value="(payload or {}).get('email', '')" class="form-control"/>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Mobile Number</label>
                                            <input type="text" name="mobile" t-att-value="(payload or {}).get('mobile', '')" class="form-control" required="required"/>
                                        </div>
                                        <div class="col-12">
                                            <button type="submit" class="btn btn-primary w-100">Send OTP</button>
                                        </div>
                                    </form>

                                    <form t-if="otp_sent" action="/otp/signup/verify" method="post" class="mt-3">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <div class="mb-3">
                                            <label class="form-label">OTP Code</label>
                                            <input type="text" name="code" class="form-control" required="required"/>
                                            <small class="text-muted">Code sent to <t t-esc="masked_mobile"/>.</small>
                                        </div>
                                        <button type="submit" class="btn btn-success w-100">Verify and Create Account</button>
                                    </form>

                                    <div class="text-center mt-3">
                                        <a href="/web/login">Back to login</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <template id="otp_checkout_page" name="OTP Checkout Page">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <section class="container py-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-6 col-md-8">
                            <div class="card shadow-sm">
                                <div class="card-body p-4">
                                    <h2 class="h4 mb-3 text-center">Checkout OTP Verification</h2>
                                    <p class="text-muted text-center">Verify the mobile number before continuing to payment.</p>
                                    <div t-if="sale_order" class="alert alert-secondary">
                                        <strong>Order:</strong>
                                        <span t-esc="sale_order.name"/>
                                    </div>
                                    <div t-if="error" class="alert alert-danger" t-esc="error"/>
                                    <div t-if="success" class="alert alert-success" t-esc="success"/>

                                    <form t-if="not otp_sent" action="/otp/checkout/send" method="post" class="mt-3">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <div class="mb-3">
                                            <label class="form-label">Mobile Number</label>
                                            <input type="text" name="mobile" t-att-value="sale_order and (sale_order.partner_id.mobile or sale_order.partner_id.phone) or ''" class="form-control" required="required"/>
                                        </div>
                                        <button type="submit" class="btn btn-primary w-100">Send OTP</button>
                                    </form>

                                    <form t-if="otp_sent" action="/otp/checkout/verify" method="post" class="mt-3">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <div class="mb-3">
                                            <label class="form-label">OTP Code</label>
                                            <input type="text" name="code" class="form-control" required="required"/>
                                            <small class="text-muted">Code sent to <t t-esc="masked_mobile"/>.</small>
                                        </div>
                                        <button type="submit" class="btn btn-success w-100">Verify and Continue</button>
                                    </form>

                                    <div class="text-center mt-3">
                                        <a href="/shop/cart">Back to cart</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
