<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_saran_otp_code_tree" model="ir.ui.view">
        <field name="name">saran.otp.code.tree</field>
        <field name="model">saran.otp.code</field>
        <field name="arch" type="xml">
            <tree>
                <field name="create_date"/>
                <field name="purpose"/>
                <field name="mobile"/>
                <field name="state"/>
                <field name="user_id"/>
                <field name="partner_id"/>
                <field name="sale_order_id"/>
                <field name="expires_at"/>
                <field name="attempts_count"/>
            </tree>
        </field>
    </record>

    <record id="view_saran_otp_code_form" model="ir.ui.view">
        <field name="name">saran.otp.code.form</field>
        <field name="model">saran.otp.code</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="purpose"/>
                            <field name="mobile"/>
                            <field name="state"/>
                            <field name="reference"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="partner_id"/>
                            <field name="sale_order_id"/>
                            <field name="expires_at"/>
                            <field name="verified_at"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="attempts_count"/>
                            <field name="max_attempts"/>
                            <field name="last_error"/>
                        </group>
                        <group>
                            <field name="metadata_json"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_saran_otp_code_search" model="ir.ui.view">
        <field name="name">saran.otp.code.search</field>
        <field name="model">saran.otp.code</field>
        <field name="arch" type="xml">
            <search>
                <field name="mobile"/>
                <field name="purpose"/>
                <field name="state"/>
                <field name="reference"/>
                <filter string="Active" name="active_sent" domain="[('state', '=', 'sent')]"/>
                <filter string="Verified" name="verified" domain="[('state', '=', 'verified')]"/>
                <filter string="Expired" name="expired" domain="[('state', '=', 'expired')]"/>
            </search>
        </field>
    </record>

    <record id="action_saran_otp_code" model="ir.actions.act_window">
        <field name="name">OTP Codes</field>
        <field name="res_model">saran.otp.code</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
