<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_saran_otp_code_tree" model="ir.ui.view">
        <field name="name">saran.otp.code.tree</field>
        <field name="model">saran.otp.code</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="mobile"/>
                <field name="purpose"/>
                <field name="state"/>
                <field name="user_id"/>
                <field name="partner_id"/>
                <field name="expires_at"/>
                <field name="used_at"/>
                <field name="attempts"/>
                <field name="gateway_status"/>
            </list>
        </field>
    </record>

    <record id="view_saran_otp_code_form" model="ir.ui.view">
        <field name="name">saran.otp.code.form</field>
        <field name="model">saran.otp.code</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="mobile"/>
                            <field name="purpose"/>
                            <field name="state"/>
                            <field name="user_id"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="expires_at"/>
                            <field name="used_at"/>
                            <field name="attempts"/>
                            <field name="request_ip"/>
                            <field name="sms_uuid"/>
                            <field name="gateway_status"/>
                        </group>
                    </group>
                    <group>
                        <field name="message"/>
                        <field name="signup_payload" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_saran_otp_code_search" model="ir.ui.view">
        <field name="name">saran.otp.code.search</field>
        <field name="model">saran.otp.code</field>
        <field name="arch" type="xml">
            <search>
                <field name="mobile"/>
                <field name="purpose"/>
                <field name="state"/>
                <filter string="Pending" name="pending" domain="[('state','=','pending')]"/>
                <filter string="Used" name="used" domain="[('state','=','used')]"/>
                <filter string="Expired" name="expired" domain="[('state','=','expired')]"/>
            </search>
        </field>
    </record>

    <record id="action_saran_otp_code" model="ir.actions.act_window">
        <field name="name">OTP Codes</field>
        <field name="res_model">saran.otp.code</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_saran_otp_code_search"/>
    </record>
</odoo>
